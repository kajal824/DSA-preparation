// T.C : O(n)
// S.C : O(1)

class Solution {
    public boolean validDigit(int n, int x) {

        String dig = Integer.toString(n);
        char tar = (char) (x + '0');
        

        
            if(dig.charAt(0) == tar){
                return false;
            }
            for(int j=1 ; j<dig.length(); j++){
                if(dig.charAt(j)==tar){
                    return true;
                }
            }
        
        return false;


        
    }
}