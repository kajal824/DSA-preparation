// T.C : O(n^2)
//S.c : O(1)


class Solution {
    public List<Integer> findValidElements(int[] nums) {
        int n = nums.length;

        List<Integer> l = new ArrayList<>(nums.length);
        if(n == 0 && n==1){
            l.add(nums[0]);
            return l;
        }

        for(int i=0; i<n; i++){
            if(i==0 || i==n-1){
                l.add(nums[i]);
                continue;
            }
            boolean leftmx = true;
            for(int j=0; j<i; j++){
                if(nums[i]<=nums[j]){
                    leftmx = false;
                    break;
                }
                
            }
            boolean rightmx = true;
            for(int j=i+1; j<n; j++){
                if(nums[i] <= nums[j]){
                    rightmx = false;
                    break;
                
                }    
            }

            if(leftmx || rightmx){
                l.add(nums[i]);
            }
        }

        return l;
        

       
            
            
        
    }
}