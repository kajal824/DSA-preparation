// A very simple and easy Solution.
// T.C : O(n). 



class Solution {
    public int getMinDistance(int[] nums, int target, int start) {
        int mindist = Integer.MAX_VALUE; 
        
        for(int  i=0; i<nums.length;i++){
            if(nums[i]== target){
                int currdist = Math.abs(i-start);

                if(currdist<mindist){
                    mindist = currdist;

                }
                
            }
            
            
        }
        return mindist;
    }
}