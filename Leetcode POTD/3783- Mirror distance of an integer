
//T.C = O(log₁₀ n)
//S.C = O(1)


class Solution {
    public int mirrorDistance(int n) {
        int rev=0;
        int original = n;
        while(n>0){
           int rem = n%10;

           rev = rev*10+rem;

           n /=10; 

        }

        int ans = Math.abs(original-rev);

        return ans;
        
    }
}