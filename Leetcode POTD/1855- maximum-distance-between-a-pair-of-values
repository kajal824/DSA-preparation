//T.C = O(m*n)
// S.C= O(1)


class Solution {
    public int maxDistance(int[] nums1, int[] nums2) {
        int m = nums1.length;
        int n  = nums2.length;
        int i = 0;
        int j = 0;
        int ans = 0;
        while(i<m && j<n){
            if(nums1[i]<=nums2[j]){
                ans = Math.max(ans,j-i);
                j++;
            }
            else{
                i++;
            }
        }
        return ans;

        
    }
}